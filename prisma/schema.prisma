generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ========== AUTH ==========
enum Role {
  DEVELOPER
  OPTICIAN
  EMPLOYEE
}

model Shop {
  id        String   @id @default(cuid())
  name      String
  address   String?
  phone     String?
  ice       String?
  city      String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users   User[]
  stores  Store[]
  clients Client[]
  frames  Frame[]
  lenses  Lens[]
  orders  Order[]

  @@map("shops")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         Role     @default(EMPLOYEE)
  active       Boolean  @default(true)

  shopId String?
  shop   Shop?   @relation(fields: [shopId], references: [id], onDelete: Cascade)

  deviceTokens DeviceToken[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model DeviceToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  shopId    String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("device_tokens")
}

// ========== PANORAMA ==========
model Store {
  id        String     @id @default(cuid())
  name      String
  imageUrl  String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  shopId String?
  shop   Shop?   @relation(fields: [shopId], references: [id], onDelete: Cascade)

  hotspots  Hotspot[]

  @@map("stores")
}

model Hotspot {
  id        String     @id @default(cuid())
  storeId   String
  store     Store      @relation(fields: [storeId], references: [id], onDelete: Cascade)

  module    String
  label     String

  x         Float
  y         Float
  w         Float
  h         Float

  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@unique([storeId, module])
  @@map("hotspots")
}

// ========== CLIENTS ==========
model Client {
  id          String     @id @default(cuid())
  firstName   String
  lastName    String
  email       String?    @unique
  phone       String?
  address     String?
  birthDate   DateTime?

  shopId String?
  shop   Shop?   @relation(fields: [shopId], references: [id], onDelete: Cascade)

  prescriptions Prescription[]
  purchases   Purchase[]
  appointments Appointment[]
  orders      Order[]

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@map("clients")
}

model Prescription {
  id          String     @id @default(cuid())
  clientId    String
  client      Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)

  dateIssued  DateTime
  sphereOD    Float?
  sphereOS    Float?
  cylinderOD  Float?
  cylinderOS  Float?
  axisOD      Float?
  axisOS      Float?
  additionOD  Float?
  additionOS  Float?
  notes       String?
  imageUrl    String?

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@map("prescriptions")
}

model Appointment {
  id          String     @id @default(cuid())
  clientId    String
  client      Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)

  dateTime    DateTime
  status      String
  notes       String?

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@map("appointments")
}

// ========== EYEWEAR ==========
model Frame {
  id          String     @id @default(cuid())
  brand       String
  model       String
  category    String
  color       String?
  price       Float
  stock       Int        @default(0)
  description String?
  barcode     String?

  shopId String?
  shop   Shop?   @relation(fields: [shopId], references: [id], onDelete: Cascade)

  purchases   Purchase[]
  orders      Order[]

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@map("frames")
}

// ========== LENSES ==========
model Lens {
  id          String     @id @default(cuid())
  type        String
  material    String
  coating     String?
  treatment   String?
  price       Float
  stock       Int        @default(0)
  description String?
  barcode     String?

  shopId String?
  shop   Shop?   @relation(fields: [shopId], references: [id], onDelete: Cascade)

  orderItems  OrderItem[]

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@map("lenses")
}

// ========== ATELIER ==========
model Order {
  id          String     @id @default(cuid())
  orderNumber String     @unique
  orderType   String     @default("sale_montage") // "sale" | "montage" | "sale_montage"

  clientId String?
  client   Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  frameId String?
  frame   Frame?  @relation(fields: [frameId], references: [id])

  items       OrderItem[]

  shopId String?
  shop   Shop?   @relation(fields: [shopId], references: [id], onDelete: Cascade)

  status      String
  totalPrice  Float
  laborPrice  Float?
  notes       String?
  deliveryDate DateTime?

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@map("orders")
}

model OrderItem {
  id          String     @id @default(cuid())
  orderId     String
  order       Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)

  lensId      String
  lens        Lens       @relation(fields: [lensId], references: [id])

  quantity    Int
  pricePerUnit Float

  @@map("order_items")
}

model Purchase {
  id          String     @id @default(cuid())
  clientId    String
  client      Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)

  frameId     String
  frame       Frame      @relation(fields: [frameId], references: [id])

  quantity    Int
  totalPrice  Float
  purchaseDate DateTime   @default(now())

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@map("purchases")
}